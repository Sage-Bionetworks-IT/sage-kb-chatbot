{
  "name": "Review Before Push",
  "version": "1.1.0",
  "description": "Verify tests pass and no secrets in diff before any git push operation",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      ".*git.*push.*"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A git push is about to happen. Before proceeding, verify: 1) All tests pass, 2) No hardcoded secrets in the diff, 3) Commit messages follow conventional format."
  }
}
